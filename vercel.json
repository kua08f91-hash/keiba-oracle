{
  "buildCommand": "",
  "outputDirectory": "docs",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://keiba-oracle-api.up.railway.app/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
